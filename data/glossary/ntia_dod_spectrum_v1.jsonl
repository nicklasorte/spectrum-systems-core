{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"CBRS","aliases":["Citizens Broadband Radio Service"],"definition":"A three-tier spectrum-sharing framework in 3.55-3.7 GHz administered by the FCC, governing incumbent, PAL, and GAA access via SAS coordination.","authoritative_source":"47 CFR 96","category":"spectrum_sharing_framework","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.5}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"FSS","aliases":["Fixed Satellite Service"],"definition":"A radiocommunication service between earth stations at given positions using one or more satellites; one position may be specified.","authoritative_source":"47 CFR 2.106","category":"spectrum_service_class","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.5}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"MSS","aliases":["Mobile Satellite Service"],"definition":"A radiocommunication service between mobile earth stations and one or more space stations, or between space stations used by this service.","authoritative_source":"47 CFR 2.106","category":"spectrum_service_class","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.5}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"FS","aliases":["Fixed Service"],"definition":"A radiocommunication service between specified fixed points.","authoritative_source":"47 CFR 2.106","category":"spectrum_service_class","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":true,"co_occurring_terms":["service","radiocommunication","band","spectrum"],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"ARS","aliases":["Amateur Radio Service"],"definition":"A radiocommunication service for the purpose of self-training, intercommunication, and technical investigations carried out by amateurs.","authoritative_source":"47 CFR 2.106","category":"spectrum_service_class","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"BSS","aliases":["Broadcasting Satellite Service"],"definition":"A radiocommunication service in which signals transmitted by space stations are intended for direct reception by the general public.","authoritative_source":"47 CFR 2.106","category":"spectrum_service_class","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"EESS","aliases":["Earth Exploration-Satellite Service"],"definition":"A radiocommunication service for collecting information about Earth from active or passive sensors on satellites.","authoritative_source":"47 CFR 2.106","category":"spectrum_service_class","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"RDSS","aliases":["Radiodetermination Satellite Service"],"definition":"A radiocommunication service for the purpose of radiodetermination involving the use of one or more space stations.","authoritative_source":"47 CFR 2.106","category":"spectrum_service_class","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"SRS","aliases":["Space Research Service"],"definition":"A radiocommunication service in which spacecraft or other objects in space are used for scientific or technological research purposes.","authoritative_source":"47 CFR 2.106","category":"spectrum_service_class","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"ISS","aliases":["Inter-Satellite Service"],"definition":"A radiocommunication service providing links between artificial satellites.","authoritative_source":"47 CFR 2.106","category":"spectrum_service_class","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"RAS","aliases":["Radio Astronomy Service"],"definition":"A passive radiocommunication service involving the reception of cosmic radio waves for astronomical research.","authoritative_source":"47 CFR 2.106","category":"spectrum_service_class","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"ITS","aliases":["Institute for Telecommunication Sciences"],"definition":"The research and engineering laboratory of NTIA, providing technical expertise on spectrum management, propagation, and radio system performance.","authoritative_source":"NTIA Manual","category":"agency","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"primary","aliases":["primary service","primary allocation"],"definition":"A service whose stations have priority over stations of a secondary service in the same band; primary stations are entitled to protection from secondary-service stations.","authoritative_source":"47 CFR 2.105","category":"spectrum_allocation_term","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":true,"co_occurring_terms":["service","allocation","secondary","band"],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"secondary","aliases":["secondary service","secondary allocation"],"definition":"A service whose stations must not cause harmful interference to primary-service stations and cannot claim protection from them; can claim protection from other secondary stations assigned later.","authoritative_source":"47 CFR 2.105","category":"spectrum_allocation_term","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":true,"co_occurring_terms":["service","allocation","primary","band"],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"co-primary","aliases":["co-primary service","coprimary"],"definition":"Two or more services sharing a band on a primary basis with equal rights to protection from interference.","authoritative_source":"47 CFR 2.105","category":"spectrum_allocation_term","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"allocation","aliases":["frequency allocation","spectrum allocation","band allocation"],"definition":"The entry of a frequency band in the Table of Frequency Allocations for use by one or more terrestrial or space radiocommunication services under specified conditions.","authoritative_source":"47 CFR 2.1","category":"spectrum_allocation_term","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":true,"co_occurring_terms":["band","frequency","spectrum"],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"assignment","aliases":["frequency assignment","channel assignment"],"definition":"Authorization given by a national administration for a radio station to use a radio frequency or channel under specified conditions.","authoritative_source":"47 CFR 2.1","category":"spectrum_allocation_term","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":true,"co_occurring_terms":["frequency","channel","band","spectrum"],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"footnote","aliases":["allocation footnote","ITU footnote","US footnote"],"definition":"A textual qualifier in the Table of Frequency Allocations that modifies the terms, conditions, or geographic scope of an allocation entry.","authoritative_source":"47 CFR 2.106","category":"spectrum_allocation_term","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":true,"co_occurring_terms":["allocation","band","frequency","table"],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"DFS","aliases":["Dynamic Frequency Selection"],"definition":"A mechanism by which a device monitors a radio channel and vacates it when a higher-priority user (typically radar) is detected.","authoritative_source":"47 CFR 15.407","category":"spectrum_sharing_framework","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"GMF","aliases":["Government Master File"],"definition":"The NTIA database of record for all federal radio frequency assignments, used for coordination and interference protection analysis.","authoritative_source":"NTIA Manual","category":"agency","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"IRAC","aliases":["Interdepartment Radio Advisory Committee"],"definition":"The principal federal interagency advisory committee that advises NTIA on spectrum policy and coordinates federal spectrum use.","authoritative_source":"NTIA Manual","category":"agency","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"NTIA","aliases":["National Telecommunications and Information Administration"],"definition":"The executive-branch agency principally responsible for advising the President on telecommunications and information policy and for managing federal use of the radio spectrum.","authoritative_source":"NTIA Manual","category":"agency","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.5}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"FCC","aliases":["Federal Communications Commission"],"definition":"The independent U.S. government agency that regulates interstate and international communications by radio, television, wire, satellite, and cable.","authoritative_source":"47 CFR 0","category":"agency","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.5}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"ITU","aliases":["International Telecommunication Union"],"definition":"The United Nations specialized agency for information and communication technologies, responsible for international spectrum coordination via the Radio Regulations.","authoritative_source":"ITU-R","category":"agency","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"PFD","aliases":["Power Flux Density"],"definition":"The power per unit area incident on a surface, expressed in dBW/m^2 in a reference bandwidth; used as a protection threshold for victim receivers.","authoritative_source":"ITU-R F.758","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.3}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"EIRP","aliases":["Equivalent Isotropically Radiated Power","Effective Isotropic Radiated Power"],"definition":"The power that an isotropic antenna would radiate to produce the peak power density observed in the direction of maximum antenna gain.","authoritative_source":"47 CFR 2.1","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.3}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"ERP","aliases":["Effective Radiated Power"],"definition":"The product of the antenna power input and the antenna power gain referenced to a half-wave dipole in a given direction.","authoritative_source":"47 CFR 2.1","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.3}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"I/N","aliases":["Interference-to-Noise ratio"],"definition":"The ratio of aggregate interference power to receiver thermal-noise power at the victim receiver input, expressed in dB; common protection criterion (e.g., -6 dB I/N).","authoritative_source":"ITU-R F.758","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.3}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"C/I","aliases":["Carrier-to-Interference ratio"],"definition":"The ratio of the carrier power of a desired signal to the aggregate power of interfering signals at the victim receiver input, expressed in dB.","authoritative_source":"ITU-R F.758","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"protection ratio","aliases":["protection criterion"],"definition":"The minimum value of the wanted-to-unwanted signal ratio (typically C/I or I/N) required at the receiver input to obtain a specified reception quality.","authoritative_source":"ITU-R F.758","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"adjacent band","aliases":["adjacent-band","adjacent channel"],"definition":"A frequency band immediately above or below the band of interest, where out-of-band emissions and receiver selectivity govern coexistence.","authoritative_source":"ITU-R SM.329","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"TIG","aliases":["Technical Implementation Group"],"definition":"An interagency working group convened under IRAC or NTIA to perform technical studies supporting a spectrum management decision.","authoritative_source":"NTIA Manual","category":"procedural_term","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"study plan","aliases":["technical study plan"],"definition":"A documented set of objectives, assumptions, scenarios, and analytical methods agreed upon at the start of a coexistence or sharing study.","authoritative_source":"NTIA Manual","category":"procedural_term","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"working paper","aliases":["WP"],"definition":"An interim technical document produced by a study group or working party to capture analysis, assumptions, and proposed text for a subsequent report or recommendation.","authoritative_source":"ITU-R","category":"procedural_term","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"characteristics document","aliases":["system characteristics document"],"definition":"A technical reference document enumerating the deployment, antenna, propagation, and emission parameters of a radio system for coexistence analysis.","authoritative_source":"ITU-R F.758","category":"procedural_term","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"SAS","aliases":["Spectrum Access System"],"definition":"An automated frequency-coordination system that authorizes CBRS device operation and protects incumbent users in 3.55-3.7 GHz.","authoritative_source":"47 CFR 96","category":"spectrum_sharing_framework","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.3}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"PAL","aliases":["Priority Access License"],"definition":"A CBRS license tier granting priority access to spectrum in a defined geographic area, between Incumbent Access and General Authorized Access.","authoritative_source":"47 CFR 96","category":"spectrum_sharing_framework","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"GAA","aliases":["General Authorized Access"],"definition":"The lowest CBRS access tier, permitting opportunistic use of spectrum not in use by Incumbents or Priority Access Licensees.","authoritative_source":"47 CFR 96","category":"spectrum_sharing_framework","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"incumbent","aliases":["incumbent user","Incumbent Access"],"definition":"The pre-existing authorized user of a frequency band whose continued operation is protected when secondary or sharing users are introduced.","authoritative_source":"47 CFR 96","category":"spectrum_sharing_framework","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":true,"co_occurring_terms":["band","spectrum","user","operation","access"],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"CBSD","aliases":["Citizens Broadband Radio Service Device"],"definition":"A radio device authorized to operate in the CBRS band under SAS coordination at Category A (lower power, indoor) or Category B (higher power, outdoor).","authoritative_source":"47 CFR 96","category":"spectrum_sharing_framework","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"DPA","aliases":["Dynamic Protection Area"],"definition":"A CBRS-specific protection zone whose extent varies with the active incumbent's operational status, computed and enforced by the SAS.","authoritative_source":"47 CFR 96","category":"spectrum_sharing_framework","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"AFC","aliases":["Automated Frequency Coordination"],"definition":"An automated coordination system used in the 6 GHz Unlicensed-National-Information-Infrastructure-5 and -7 bands to authorize standard-power device operation while protecting incumbent fixed services.","authoritative_source":"47 CFR 15.407","category":"spectrum_sharing_framework","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"UNII","aliases":["Unlicensed National Information Infrastructure","U-NII"],"definition":"A set of unlicensed 5 GHz and 6 GHz frequency bands subject to FCC technical rules including DFS and (in 6 GHz) AFC.","authoritative_source":"47 CFR 15.407","category":"spectrum_sharing_framework","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"WRC","aliases":["World Radiocommunication Conference"],"definition":"The ITU treaty conference held approximately every four years that revises the international Radio Regulations governing global spectrum allocations.","authoritative_source":"ITU-R","category":"procedural_term","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"ITU-R","aliases":["ITU Radiocommunication Sector"],"definition":"The Radiocommunication Sector of the ITU, which produces Recommendations and Reports on radio system characteristics, sharing studies, and the Radio Regulations.","authoritative_source":"ITU-R","category":"agency","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"CEPT","aliases":["European Conference of Postal and Telecommunications Administrations"],"definition":"A European-region body that coordinates spectrum and telecommunications policy among its member administrations and publishes ECC Decisions and Reports.","authoritative_source":"ITU-R","category":"agency","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"3GPP","aliases":["3rd Generation Partnership Project"],"definition":"The international standards organization that develops technical specifications for cellular telecommunications systems including 4G LTE and 5G NR.","authoritative_source":"3GPP TS 38.101","category":"agency","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"coordination zone","aliases":["coordination area"],"definition":"A geographic area surrounding a protected receiver within which a new transmitter must coordinate with the incumbent to avoid harmful interference.","authoritative_source":"ITU-R F.758","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"exclusion zone","aliases":["exclusion area","keep-out zone"],"definition":"A geographic area within which a particular class of transmitters is prohibited from operating, typically to protect a sensitive incumbent receiver.","authoritative_source":"ITU-R F.758","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"coordination distance","aliases":["coordination radius"],"definition":"The distance from a protected receiver beyond which a new transmitter is presumed not to cause harmful interference under stated propagation and emission assumptions.","authoritative_source":"ITU-R F.758","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"harmful interference","aliases":["harmful-interference"],"definition":"Interference that endangers the functioning of a radionavigation service or of other safety services or seriously degrades, obstructs, or repeatedly interrupts a radiocommunication service operating in accordance with the Radio Regulations.","authoritative_source":"47 CFR 2.1","category":"protection_standard","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.2}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"propagation model","aliases":["propagation prediction model"],"definition":"A mathematical model used to estimate the path loss between a transmitter and receiver as a function of distance, frequency, terrain, and clutter.","authoritative_source":"ITU-R P.452","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"spurious emission","aliases":["spurious emissions"],"definition":"Emission on a frequency or frequencies outside the necessary bandwidth and the out-of-band domain, whose level can be reduced without affecting transmission of information.","authoritative_source":"ITU-R SM.329","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"out-of-band emission","aliases":["out-of-band emissions","OOB emission"],"definition":"Emission on a frequency or frequencies immediately outside the necessary bandwidth that results from the modulation process, excluding spurious emissions.","authoritative_source":"ITU-R SM.329","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"OOBE","aliases":["Out-of-Band Emission"],"definition":"Emission on a frequency or frequencies immediately outside the necessary bandwidth that results from the modulation process, excluding spurious emissions.","authoritative_source":"ITU-R SM.329","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":true,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"spectral mask","aliases":["transmit spectrum mask","emission mask"],"definition":"A frequency-domain template that constrains the maximum permitted power spectral density of a transmitter's emissions as a function of offset from the assigned carrier frequency.","authoritative_source":"47 CFR 27.53","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
{"artifact_type":"glossary_entry","schema_version":"1.0.0","term":"duty cycle","aliases":["transmit duty cycle"],"definition":"The fraction of time a transmitter is actively emitting energy, expressed as a percentage; used in aggregate interference calculations.","authoritative_source":"ITU-R F.758","category":"technical_threshold","created_at":"2026-05-20T00:00:00Z","is_acronym":false,"disambiguation_required":false,"co_occurring_terms":[],"priority_weight":1.0}
