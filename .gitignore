__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
build/
dist/
.venv/

# Phase I governance: audit-time outputs are runtime data, not source.
governance/audits/*.json
!governance/audits/index.json
governance/candidates/*.json
governance/candidates/archive/*.json
governance/drift/*.jsonl
governance/markdown/*.md

# Data-lake separation (non-negotiable):
#
# All pipeline artifacts, transcripts, minutes, processed data, and
# every other data file live in the separate `nicklasorte/data-lake`
# repository. Workflows clone it into `data-lake/` at run time via
# `DATA_LAKE_TOKEN`. The directory MUST be gitignored here so a
# stray `git add data-lake` cannot re-commit the contents into
# spectrum-systems-core.
#
# Do NOT add per-subpath negations under `data-lake/`. The data-lake
# repo has its own `.gitignore`; per-artifact gitignore enforcement is
# that repo's responsibility. The pre-PR `_gitignore_audit.py` script
# verifies the `data-lake/` rule below is present and (when a local
# clone exists) walks the manifest against the data-lake repo's own
# gitignore.
data-lake/

# Local non-data-lake runtime byproducts.
raw/
