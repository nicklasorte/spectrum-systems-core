__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
build/
dist/
.venv/

# Phase I governance: audit-time outputs are runtime data, not source.
governance/audits/*.json
!governance/audits/index.json
governance/candidates/*.json
governance/candidates/archive/*.json
governance/drift/*.jsonl
governance/markdown/*.md

# Same governance outputs when DATA_LAKE_PATH points at the in-repo
# data-lake/. The data-lake tree is runtime data; nothing under
# data-lake/store/governance/ is part of the repo baseline.
data-lake/store/governance/

# Phase V + W: feature flags and model registry are seeded by
# scripts/seed_phase_*_flag.py and operator commands. They are
# data-lake state, not repo source.
data-lake/store/artifacts/config/
data-lake/store/artifacts/agenda/
data-lake/store/artifacts/verifications/
# NOTE: data-lake/store/artifacts/extractions/ is intentionally NOT
# ignored. The debug-single-transcript workflow commits the
# meeting_extraction artifact produced by typed_extraction_runner so
# downstream workflows (select-few-shot-candidates,
# eval-ground-truth, validate-and-baseline) can read it. The
# preflight in scripts/_few_shot_preflight.py looks for files under
# data-lake/store/artifacts/extractions/; gitignoring that path
# silently blocked `git add store/artifacts/` in the debug
# workflow's commit step and caused the preflight to fail with
# exit code 2.

# Pipeline runtime data — bulk pipeline data lives under DATA_LAKE_PATH,
# not the repo. Bulk processed/ contents (text_units.jsonl, chunks.jsonl,
# stories/, etc.) stay ignored, but the small source_record.json metadata
# file is un-ignored so the few-shot preflight in
# scripts/_few_shot_preflight.py can map a slug source_id (e.g.
# "7-ghz-downlink-tig-meeting-kickoff---transcript-20251218") to the UUID
# source_artifact_id used as the meeting_extraction filename prefix. The
# debug-single-transcript workflow's `git add store/processed/` step relies
# on this negation to commit source_record.json after each run.
raw/
**/processed/**
!**/processed/**/
!**/processed/**/source_record.json
