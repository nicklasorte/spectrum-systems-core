{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/orchestration/orchestration_run_record.schema.json",
  "title": "orchestration_run_record",
  "description": "Per-invocation record of a PipelineOrchestrator run. Written to $SDL_ROOT/orchestration/<run_id>.json after every run() call (including dry runs and partial failures).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "started_at",
    "completed_at",
    "dry_run",
    "force",
    "force_only_missing",
    "specific_source_id",
    "data_lake_path",
    "transcripts_found",
    "already_processed",
    "attempted_this_run",
    "succeeded_this_run",
    "failed_this_run",
    "filtered_from_transcripts",
    "results",
    "source_ids_skipped",
    "source_ids_processed",
    "source_ids_failed",
    "status",
    "synthesize_status",
    "total_stages_completed",
    "total_stages_failed",
    "schema_version",
    "provenance"
  ],
  "properties": {
    "run_id": { "type": "string", "format": "uuid" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "dry_run": { "type": "boolean" },
    "force": { "type": "boolean" },
    "force_only_missing": { "type": "boolean" },
    "specific_source_id": { "type": ["string", "null"] },
    "data_lake_path": { "type": "string", "minLength": 1 },
    "transcripts_found": { "type": "integer", "minimum": 0 },
    "already_processed": { "type": "integer", "minimum": 0 },
    "attempted_this_run": { "type": "integer", "minimum": 0 },
    "succeeded_this_run": { "type": "integer", "minimum": 0 },
    "failed_this_run": { "type": "integer", "minimum": 0 },
    "synthesize_status": {
      "type": "string",
      "enum": ["success", "skipped", "failure", "not_run"]
    },
    "total_stages_completed": { "type": "integer", "minimum": 0 },
    "total_stages_failed": { "type": "integer", "minimum": 0 },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "filename",
          "status",
          "artifact_id",
          "reason",
          "eval_status",
          "pipeline_stages"
        ],
        "properties": {
          "filename": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failure",
              "skipped_already_done",
              "would_run",
              "extraction_quality_warning",
              "filtered"
            ]
          },
          "artifact_id": { "type": "string" },
          "reason": { "type": "string" },
          "eval_status": {
            "type": "string",
            "enum": ["passed", "warning", "failed", "not_run"]
          },
          "pipeline_stages": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "process_source",
              "extract_stories",
              "promote_knowledge",
              "extract_claims"
            ],
            "properties": {
              "process_source": {
                "type": "string",
                "enum": ["success", "skipped", "failure", "forced", "not_run"]
              },
              "extract_stories": {
                "type": "string",
                "enum": ["success", "skipped", "failure", "forced", "not_run"]
              },
              "promote_knowledge": {
                "type": "string",
                "enum": ["success", "skipped", "failure", "forced", "not_run"]
              },
              "extract_claims": {
                "type": "string",
                "enum": ["success", "skipped", "failure", "forced", "not_run"]
              }
            }
          }
        }
      }
    },
    "filtered_from_transcripts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["filename", "reason"],
        "properties": {
          "filename": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "source_ids_skipped": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source_ids_processed": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source_ids_failed": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failure", "dry_run"]
    },
    "schema_version": { "const": "1.4.0" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by"],
      "properties": {
        "produced_by": { "const": "PipelineOrchestrator" }
      }
    }
  }
}
