{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/harness/entropy_report.schema.json",
  "title": "entropy_report",
  "description": "Periodic entropy/complexity audit. Each flagged_item carries a recommended_action a human acts on via CLI; the audit NEVER auto-deletes or auto-merges (FINDING-G-007).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "generated_at",
    "scope",
    "flagged_items",
    "total_flagged",
    "total_scanned"
  ],
  "properties": {
    "report_id": { "type": "string", "format": "uuid" },
    "generated_at": { "type": "string", "format": "date-time" },
    "scope": { "type": "string" },
    "flagged_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_type",
          "item_id",
          "reason",
          "recommended_action",
          "severity"
        ],
        "properties": {
          "item_type": { "type": "string", "minLength": 1 },
          "item_id": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "recommended_action": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["high", "medium", "low"] }
        }
      }
    },
    "total_flagged": { "type": "integer", "minimum": 0 },
    "total_scanned": { "type": "integer", "minimum": 0 }
  }
}
