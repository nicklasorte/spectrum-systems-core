{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/agency/agency_profile.schema.json",
  "title": "agency_profile",
  "description": "One agency_profile per agency_slug directory. Uniqueness of agency_name and aliases is enforced by AliasNormalizer at write time, not by schema (CHECK-RT1-001).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "agency_name",
    "agency_slug",
    "aliases",
    "jurisdiction",
    "description",
    "active",
    "created_at",
    "updated_at",
    "total_comment_count",
    "total_objection_count",
    "provenance"
  ],
  "properties": {
    "profile_id": { "type": "string", "format": "uuid" },
    "agency_name": { "type": "string", "minLength": 2 },
    "agency_slug": { "type": "string", "pattern": "^[a-z0-9_-]{2,64}$" },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "jurisdiction": { "type": "string" },
    "description": { "type": "string" },
    "active": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "total_comment_count": { "type": "integer", "minimum": 0 },
    "total_objection_count": { "type": "integer", "minimum": 0 },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by", "execution_fingerprint_hash"],
      "properties": {
        "produced_by": {
          "type": "object",
          "additionalProperties": false,
          "required": ["component", "version"],
          "properties": {
            "component": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "execution_fingerprint_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    }
  }
}
