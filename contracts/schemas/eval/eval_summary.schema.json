{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/eval/eval_summary.schema.json",
  "title": "eval_summary",
  "description": "Phase M.4 artifact produced by EvalRunner. Aggregates per-pair eval_results into pipeline-run-level coverage / precision / review numbers, broken down by chunking_strategy, plus baseline-comparison fields used by RegressionGate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eval_summary_id",
    "pipeline_run_id",
    "artifact_type",
    "schema_version",
    "created_at",
    "pairs_evaluated",
    "pairs_skipped_pending_review",
    "aggregate_coverage",
    "aggregate_precision",
    "total_items_requiring_review",
    "by_chunking_strategy",
    "eval_results",
    "is_baseline",
    "baseline_eval_summary_id",
    "regression_detected",
    "regression_detail",
    "partial_run_warning",
    "partial_run_detail",
    "provenance"
  ],
  "properties": {
    "eval_summary_id": { "type": "string", "format": "uuid" },
    "pipeline_run_id": { "type": "string", "minLength": 1 },
    "artifact_type": { "const": "eval_summary" },
    "schema_version": { "type": "string", "enum": ["1.1.0", "1.2.0", "2.0.0"] },
    "created_at": { "type": "string", "format": "date-time" },
    "pairs_evaluated": { "type": "integer", "minimum": 0 },
    "pairs_skipped_pending_review": { "type": "integer", "minimum": 0 },
    "aggregate_coverage": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "aggregate_precision": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "total_items_requiring_review": { "type": "integer", "minimum": 0 },
    "by_chunking_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["speaker_turn", "character_count_fallback"],
      "properties": {
        "speaker_turn": { "$ref": "#/$defs/strategy_bucket" },
        "character_count_fallback": { "$ref": "#/$defs/strategy_bucket" },
        "unknown": { "$ref": "#/$defs/strategy_bucket" }
      }
    },
    "eval_results": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "is_baseline": { "type": "boolean" },
    "baseline_eval_summary_id": { "type": ["string", "null"] },
    "regression_detected": { "type": "boolean" },
    "regression_detail": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pair_id", "metric", "baseline_value", "current_value", "delta"],
        "properties": {
          "pair_id": { "type": "string" },
          "metric": { "enum": ["coverage", "items_requiring_review_rate"] },
          "baseline_value": { "type": "number" },
          "current_value": { "type": "number" },
          "delta": { "type": "number" }
        }
      }
    },
    "partial_run_warning": { "type": "boolean", "default": false },
    "partial_run_detail": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["expected", "actual", "missing_source_ids"],
          "properties": {
            "expected": { "type": "integer", "minimum": 0 },
            "actual": { "type": "integer", "minimum": 0 },
            "missing_source_ids": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by"],
      "properties": {
        "produced_by": { "const": "EvalRunner" }
      }
    },
    "agenda_coverage_std_deviation": {
      "type": "number", "minimum": 0.0,
      "description": "Phase W.5 (schema 1.2.0): population std-dev of per-agenda coverage across non-excluded agendas in this run."
    },
    "agenda_precision_std_deviation": {
      "type": "number", "minimum": 0.0,
      "description": "Phase W.5 (schema 1.2.0): population std-dev of per-agenda precision across non-excluded agendas in this run."
    },
    "flag_hidden_stratification": {
      "type": "boolean",
      "description": "Phase W.5 (schema 1.2.0): True iff either std-deviation exceeds 0.20 -- warn in summary output."
    },
    "pair_breakdown": {
      "type": "array",
      "description": "Phase O.4 (schema 2.0.0): one entry per evaluated ground_truth_pair. Provenance carried so a low coverage number can be traced to specific source_ids / agendas.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pair_id", "source_id", "agenda_item_id", "ground_truth_text", "matched", "match_score", "status"],
        "properties": {
          "pair_id": { "type": "string" },
          "source_id": { "type": ["string", "null"] },
          "agenda_item_id": { "type": ["string", "null"] },
          "ground_truth_text": { "type": "string" },
          "matched": { "type": "boolean" },
          "match_score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "status": { "type": "string", "enum": ["matched", "unmatched"] }
        }
      }
    },
    "per_source_metrics": {
      "type": ["object", "null"],
      "description": "Phase O.4 (schema 2.0.0): coverage / precision rolled up per source_id. Suppressed (null) when fewer than 2 distinct source_ids are present.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pairs", "matched", "coverage", "precision"],
        "properties": {
          "pairs": { "type": "integer", "minimum": 0 },
          "matched": { "type": "integer", "minimum": 0 },
          "coverage": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "precision": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "per_type_metrics": {
      "type": ["object", "null"],
      "description": "Phase T.5 (schema 2.0.0): precision / recall / F1 broken down by target_type. Suppressed (null) when any ground_truth pair lacks a target_type field; per_type_metrics_reason carries the explanation.",
      "additionalProperties": false,
      "properties": {
        "decision": { "$ref": "#/$defs/type_metrics" },
        "claim": { "$ref": "#/$defs/type_metrics" },
        "action_item": { "$ref": "#/$defs/type_metrics" }
      }
    },
    "per_type_metrics_reason": {
      "type": ["string", "null"],
      "description": "Phase T.5: non-null only when per_type_metrics is null; explains why."
    },
    "spurious_add_rate": {
      "type": "number", "minimum": 0.0, "maximum": 1.0,
      "description": "Phase T.2: fraction of extracted items with grounding_verified=false across this run."
    },
    "baseline_scope": {
      "type": ["string", "null"],
      "enum": ["single_transcript", "full_corpus", null],
      "description": "Phase X2.4: tag on the eval_summary recording whether the baseline (if this summary is one) covers a single transcript or the full corpus. Null on non-baseline summaries."
    },
    "grounding_overlap_p10": {
      "type": "number", "minimum": 0.0, "maximum": 1.0,
      "description": "Phase T.2: 10th percentile of grounding_overlap_score across extracted items."
    },
    "grounding_overlap_p50": {
      "type": "number", "minimum": 0.0, "maximum": 1.0,
      "description": "Phase T.2: median grounding_overlap_score."
    },
    "grounding_overlap_p90": {
      "type": "number", "minimum": 0.0, "maximum": 1.0,
      "description": "Phase T.2: 90th percentile of grounding_overlap_score."
    }
  },
  "$defs": {
    "strategy_bucket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coverage", "precision", "pairs_count"],
      "properties": {
        "coverage": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "precision": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "pairs_count": { "type": "integer", "minimum": 0 }
      }
    },
    "type_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["precision", "recall", "f1", "pairs_count"],
      "properties": {
        "precision": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "recall": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "f1": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "pairs_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
