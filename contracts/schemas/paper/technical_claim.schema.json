{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/paper/technical_claim.schema.json",
  "title": "technical_claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "source_id",
    "source_unit_id",
    "source_excerpt",
    "claim_text",
    "claim_type",
    "materiality",
    "supported_by_evidence_ids",
    "contradicted_by_claim_ids",
    "extraction_model",
    "extraction_temperature",
    "status",
    "created_at",
    "provenance"
  ],
  "properties": {
    "claim_id": { "type": "string", "format": "uuid" },
    "source_id": { "type": "string", "minLength": 1 },
    "source_unit_id": { "type": "string", "format": "uuid" },
    "source_excerpt": { "type": "string", "minLength": 10 },
    "claim_text": { "type": "string", "minLength": 10 },
    "claim_type": {
      "enum": ["factual", "methodological", "predictive", "normative"]
    },
    "materiality": { "enum": ["high", "medium", "low"] },
    "supported_by_evidence_ids": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "contradicted_by_claim_ids": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "extraction_model": { "type": "string", "minLength": 1 },
    "extraction_temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 0
    },
    "status": {
      "enum": ["candidate", "evidenced", "contradicted", "superseded"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "produced_by",
        "input_artifact_ids",
        "execution_fingerprint_hash"
      ],
      "properties": {
        "produced_by": {
          "type": "object",
          "additionalProperties": false,
          "required": ["component", "version"],
          "properties": {
            "component": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "input_artifact_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "execution_fingerprint_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    }
  }
}
