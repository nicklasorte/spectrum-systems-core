{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/synthesis/context_bundle.schema.json",
  "title": "context_bundle",
  "description": "Assembled context bundle for one synthesis run. Schema permits total_token_estimate > token_budget; budget enforcement is in EVAL-CTX-003, not schema (CHECK-RT1-002).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "run_id",
    "recipe_id",
    "recipe_version",
    "audience",
    "purpose",
    "items",
    "total_token_estimate",
    "token_budget",
    "bundle_hash",
    "assembled_at",
    "provenance"
  ],
  "properties": {
    "bundle_id": { "type": "string", "format": "uuid" },
    "run_id": { "type": "string", "format": "uuid" },
    "recipe_id": { "type": "string", "minLength": 1 },
    "recipe_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "audience": {
      "enum": ["technical", "policy", "executive", "public"]
    },
    "purpose": { "enum": ["report", "keynote", "both"] },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    },
    "total_token_estimate": { "type": "integer", "minimum": 0 },
    "token_budget": { "type": "integer", "minimum": 1 },
    "bundle_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "assembled_at": { "type": "string", "format": "date-time" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "produced_by",
        "input_artifact_ids",
        "execution_fingerprint_hash"
      ],
      "properties": {
        "produced_by": {
          "type": "object",
          "additionalProperties": false,
          "required": ["component", "version"],
          "properties": {
            "component": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "input_artifact_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "execution_fingerprint_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    }
  }
}
