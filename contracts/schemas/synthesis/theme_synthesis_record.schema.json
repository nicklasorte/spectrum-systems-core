{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/synthesis/theme_synthesis_record.schema.json",
  "title": "theme_synthesis_record",
  "description": "Cross-source theme synthesis record. cross_source is true when contributing_source_ids has 2 or more entries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "synthesis_id",
    "run_id",
    "theme_name",
    "theme_description",
    "contributing_source_ids",
    "contributing_story_ids",
    "contributing_claim_ids",
    "cross_source",
    "created_at"
  ],
  "properties": {
    "synthesis_id": { "type": "string", "format": "uuid" },
    "run_id": { "type": "string", "format": "uuid" },
    "theme_name": { "type": "string", "minLength": 3 },
    "theme_description": { "type": "string", "minLength": 20 },
    "contributing_source_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "contributing_story_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "contributing_claim_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "cross_source": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
