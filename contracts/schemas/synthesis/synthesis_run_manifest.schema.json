{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/synthesis/synthesis_run_manifest.schema.json",
  "title": "synthesis_run_manifest",
  "description": "Per-run synthesis manifest. total_estimated_cost_usd is computed at close_run time by summing all cost.jsonl entries (CHECK-RT1-005).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "audience",
    "purpose",
    "source_ids_included",
    "story_ids_included",
    "claim_ids_included",
    "theme_ids_included",
    "total_input_tokens",
    "total_output_tokens",
    "total_estimated_cost_usd",
    "started_at",
    "completed_at"
  ],
  "properties": {
    "run_id": { "type": "string", "format": "uuid" },
    "audience": {
      "enum": ["technical", "policy", "executive", "public"]
    },
    "purpose": { "enum": ["report", "keynote", "both"] },
    "source_ids_included": {
      "type": "array",
      "items": { "type": "string" }
    },
    "story_ids_included": {
      "type": "array",
      "items": { "type": "string" }
    },
    "claim_ids_included": {
      "type": "array",
      "items": { "type": "string" }
    },
    "theme_ids_included": {
      "type": "array",
      "items": { "type": "string" }
    },
    "total_input_tokens": { "type": "integer", "minimum": 0 },
    "total_output_tokens": { "type": "integer", "minimum": 0 },
    "total_estimated_cost_usd": { "type": "number", "minimum": 0.0 },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": {
      "anyOf": [
        { "type": "string", "format": "date-time" },
        { "type": "null" }
      ]
    }
  }
}
