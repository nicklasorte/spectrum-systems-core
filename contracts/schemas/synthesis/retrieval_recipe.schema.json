{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/synthesis/retrieval_recipe.schema.json",
  "title": "retrieval_recipe",
  "description": "A versioned retrieval recipe. promoted_only=true is enforced by the assembler at retrieval time (FINDING-F-002).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recipe_id",
    "recipe_version",
    "description",
    "sources",
    "audience_filters",
    "max_total_tokens",
    "created_at"
  ],
  "properties": {
    "recipe_id": { "type": "string", "minLength": 1 },
    "recipe_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["source_type", "max_items", "promoted_only"],
        "properties": {
          "source_type": { "type": "string", "minLength": 1 },
          "max_items": { "type": "integer", "minimum": 1 },
          "promoted_only": { "type": "boolean" },
          "filter": { "type": "string" }
        }
      }
    },
    "audience_filters": { "type": "object" },
    "max_total_tokens": { "type": "integer", "minimum": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
