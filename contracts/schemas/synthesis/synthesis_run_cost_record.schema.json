{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/synthesis/synthesis_run_cost_record.schema.json",
  "title": "synthesis_run_cost_record",
  "description": "Per-Sonnet-call cost record (FINDING-F-007). Sum across run_id is total_estimated_cost_usd.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cost_id",
    "run_id",
    "call_purpose",
    "input_tokens",
    "output_tokens",
    "estimated_cost_usd",
    "model",
    "recorded_at"
  ],
  "properties": {
    "cost_id": { "type": "string", "format": "uuid" },
    "run_id": { "type": "string", "format": "uuid" },
    "call_purpose": { "type": "string", "minLength": 1 },
    "input_tokens": { "type": "integer", "minimum": 0 },
    "output_tokens": { "type": "integer", "minimum": 0 },
    "estimated_cost_usd": { "type": "number", "minimum": 0.0 },
    "model": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" }
  }
}
