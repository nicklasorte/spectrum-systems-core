{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/synthesis/report_draft.schema.json",
  "title": "report_draft",
  "description": "A multi-section report draft. Each section's grounded flag is set by GroundingEval, not by the generator. A section with empty inline_citations and >50-char content is grounded=false (CHECK-RT1-003).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "draft_id",
    "run_id",
    "bundle_id",
    "bundle_hash",
    "audience",
    "title",
    "sections",
    "generation_model",
    "generation_temperature",
    "status",
    "created_at",
    "provenance"
  ],
  "properties": {
    "draft_id": { "type": "string", "format": "uuid" },
    "run_id": { "type": "string", "format": "uuid" },
    "bundle_id": { "type": "string", "format": "uuid" },
    "bundle_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "audience": {
      "enum": ["technical", "policy", "executive", "public"]
    },
    "title": { "type": "string", "minLength": 5 },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "section_id",
          "section_title",
          "section_type",
          "content",
          "inline_citations",
          "grounded",
          "unverified_citations"
        ],
        "properties": {
          "section_id": { "type": "string", "format": "uuid" },
          "section_title": { "type": "string", "minLength": 1 },
          "section_type": {
            "enum": [
              "executive_summary",
              "background",
              "findings",
              "analysis",
              "recommendations",
              "conclusion"
            ]
          },
          "content": { "type": "string" },
          "inline_citations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "grounded": { "type": "boolean" },
          "unverified_citations": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "generation_model": { "type": "string", "minLength": 1 },
    "generation_temperature": { "type": "number", "const": 0 },
    "status": {
      "enum": ["draft", "grounded", "reviewed", "approved", "rejected"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "produced_by",
        "input_artifact_ids",
        "execution_fingerprint_hash"
      ],
      "properties": {
        "produced_by": {
          "type": "object",
          "additionalProperties": false,
          "required": ["component", "version"],
          "properties": {
            "component": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "input_artifact_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "execution_fingerprint_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    }
  }
}
