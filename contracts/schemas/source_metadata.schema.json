{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/contracts/schemas/source_metadata.schema.json",
  "title": "source_metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_id",
    "source_family",
    "source_type",
    "title",
    "description",
    "date",
    "author",
    "tags",
    "raw_format",
    "private_use_only"
  ],
  "properties": {
    "source_id": { "type": "string", "minLength": 1 },
    "source_family": {
      "enum": ["meetings", "books", "comments", "working_papers", "notes"]
    },
    "source_type": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "author": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "raw_format": { "enum": ["txt", "md", "pdf"] },
    "private_use_only": { "type": "boolean" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "source_family": { "const": "books" } },
        "required": ["source_family"]
      },
      "then": {
        "properties": { "private_use_only": { "const": true } }
      }
    }
  ]
}
