{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/src/schemas/orchestration_result.schema.json",
  "title": "orchestration_result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "run_id",
    "source_id",
    "chunks_attempted",
    "chunks_succeeded",
    "chunks_blocked",
    "block_reasons",
    "stage_status"
  ],
  "properties": {
    "artifact_type": { "const": "orchestration_result" },
    "schema_version": { "const": "1.0.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "source_id": { "type": "string", "minLength": 1 },
    "chunks_attempted": { "type": "integer", "minimum": 0 },
    "chunks_succeeded": { "type": "integer", "minimum": 0 },
    "chunks_blocked": { "type": "integer", "minimum": 0 },
    "block_reasons": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rate_limit_exhausted",
        "empty_response",
        "parse_error",
        "other"
      ],
      "properties": {
        "rate_limit_exhausted": { "type": "integer", "minimum": 0 },
        "empty_response":       { "type": "integer", "minimum": 0 },
        "parse_error":          { "type": "integer", "minimum": 0 },
        "other":                { "type": "integer", "minimum": 0 }
      }
    },
    "stage_status": { "enum": ["ok", "partial", "failed"] },
    "created_at": { "type": "string" },
    "glossary_injection_summary": {
      "type": "object",
      "description": "Phase W (integration wiring): rollup of versioned-glossary term injections across all chunks in the run.",
      "additionalProperties": false,
      "properties": {
        "chunks_with_matches": { "type": "integer", "minimum": 0 },
        "chunks_with_no_matches": { "type": "integer", "minimum": 0 },
        "total_term_injections": { "type": "integer", "minimum": 0 },
        "most_injected_terms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stale_records_count": { "type": "integer", "minimum": 0 }
      }
    },
    "binding_tuple_call_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Phase W (integration wiring): number of decisions with a populated binding_tuple sub-object. Always 0 when BINDING_TUPLE_ENABLED=false (default)."
    },
    "scope_overgeneralization_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Phase W (integration wiring): number of scope_overgeneralization findings emitted by generalization_checker.scan_items on this run."
    }
  }
}
