{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/src/schemas/spurious_add_candidate.schema.json",
  "title": "spurious_add_candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "spurious_add_candidate_id",
    "source_id",
    "item_text",
    "evidence",
    "overlap",
    "cited_chunk_ids",
    "missing_chunk_ids",
    "threshold",
    "created_at"
  ],
  "properties": {
    "artifact_type":              { "const": "spurious_add_candidate" },
    "schema_version":             { "const": "1.0.0" },
    "spurious_add_candidate_id":  { "type": "string", "minLength": 1 },
    "source_id":                  { "type": "string" },
    "extraction_run_id":          { "type": "string" },
    "item_text":                  { "type": "string" },
    "evidence":                   { "type": "string" },
    "overlap":                    { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "cited_chunk_ids":            { "type": "array", "items": { "type": "string" } },
    "missing_chunk_ids":          { "type": "array", "items": { "type": "string" } },
    "threshold":                  { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "created_at":                 { "type": "string", "minLength": 1 }
  }
}
