{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/src/schemas/spurious_add_warning.schema.json",
  "title": "spurious_add_warning",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "spurious_add_warning_id",
    "source_id",
    "confirmed_items_count",
    "spurious_items_count",
    "spurious_add_rate",
    "threshold",
    "created_at"
  ],
  "properties": {
    "artifact_type":             { "const": "spurious_add_warning" },
    "schema_version":            { "const": "1.0.0" },
    "spurious_add_warning_id":   { "type": "string", "minLength": 1 },
    "source_id":                 { "type": "string" },
    "extraction_run_id":         { "type": "string" },
    "confirmed_items_count":     { "type": "integer", "minimum": 0 },
    "spurious_items_count":      { "type": "integer", "minimum": 0 },
    "spurious_add_rate":         { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "threshold":                 { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "created_at":                { "type": "string", "minLength": 1 }
  }
}
