{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/src/schemas/binding_warning.schema.json",
  "title": "binding_warning",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "binding_warning_id",
    "source_id",
    "decision_text",
    "binding_valid",
    "regulatory_verb_count",
    "binding_weak",
    "binding_ambiguous",
    "missing_fields",
    "warnings",
    "created_at"
  ],
  "properties": {
    "artifact_type":          { "const": "binding_warning" },
    "schema_version":         { "const": "1.0.0" },
    "binding_warning_id":     { "type": "string", "minLength": 1 },
    "source_id":              { "type": "string" },
    "extraction_run_id":      { "type": "string" },
    "decision_text":          { "type": "string" },
    "decision_type":          { "type": "string" },
    "binding_valid":          { "type": "boolean" },
    "regulatory_verb_count":  { "type": "integer", "minimum": 0 },
    "binding_weak":           { "type": "boolean" },
    "binding_ambiguous":      { "type": "boolean" },
    "missing_fields":         { "type": "array", "items": { "type": "string" } },
    "warnings":               { "type": "array", "items": { "type": "string" } },
    "created_at":             { "type": "string", "minLength": 1 }
  }
}
