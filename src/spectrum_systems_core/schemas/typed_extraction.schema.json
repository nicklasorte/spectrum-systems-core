{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/src/schemas/typed_extraction.schema.json",
  "title": "typed_extraction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "source_id",
    "extraction_run_id",
    "decisions",
    "claims",
    "action_items"
  ],
  "properties": {
    "artifact_type":   { "const": "typed_extraction" },
    "schema_version":  { "const": "1.0.0" },
    "source_id":       { "type": "string", "minLength": 1 },
    "extraction_run_id": { "type": "string", "minLength": 1 },
    "created_at":      { "type": "string" },

    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_text",
          "decision_type",
          "source_turn_ids",
          "confidence"
        ],
        "properties": {
          "decision_text": { "type": "string", "minLength": 1 },
          "decision_type": {
            "enum": [
              "approved", "rejected", "deferred", "noted", "considered",
              "action_required", "open_question", "to_be_determined"
            ]
          },
          "stakeholders": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rationale": { "type": ["string", "null"] },
          "source_turn_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "source_turn_validation": {
            "enum": ["verified", "invalid", "missing"]
          },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "items_requiring_review": { "type": "boolean" },
          "review_reason": { "type": "string" },
          "requires_human_dedup": { "type": "boolean" },
          "binding_valid": { "type": "boolean" },
          "regulatory_verb_count": { "type": "integer", "minimum": 0 },
          "binding_weak": { "type": "boolean" },
          "binding_ambiguous": { "type": "boolean" }
        }
      }
    },

    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_text",
          "claim_type",
          "source_turn_ids",
          "confidence"
        ],
        "properties": {
          "claim_text": { "type": "string", "minLength": 1 },
          "claim_type": {
            "enum": ["technical", "procedural", "regulatory", "opinion"]
          },
          "speaker": { "type": "string" },
          "source_turn_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "source_turn_validation": {
            "enum": ["verified", "invalid", "missing"]
          },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "items_requiring_review": { "type": "boolean" },
          "review_reason": { "type": "string" },
          "requires_human_dedup": { "type": "boolean" }
        }
      }
    },

    "action_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action",
          "owner",
          "source_turn_ids"
        ],
        "properties": {
          "action": { "type": "string", "minLength": 1 },
          "owner":  { "type": "string", "minLength": 1 },
          "due":    { "type": ["string", "null"] },
          "source_turn_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "source_turn_validation": {
            "enum": ["verified", "invalid", "missing"]
          },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "items_requiring_review": { "type": "boolean" },
          "review_reason": { "type": "string" },
          "requires_human_dedup": { "type": "boolean" }
        }
      }
    }
  }
}
