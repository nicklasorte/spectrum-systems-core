{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/src/schemas/meeting_extraction.schema.json",
  "title": "meeting_extraction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "meeting_extraction_id",
    "source_artifact_id",
    "created_at",
    "decisions",
    "claims",
    "action_items",
    "total_chunks_classified",
    "off_topic_count",
    "regulatory_verb_fallback_count",
    "routing_quality_warning",
    "requires_human_dedup_count",
    "extraction_run_id",
    "few_shot_injected",
    "few_shot_version",
    "few_shot_example_count",
    "omit_instruction_present",
    "confidence_threshold",
    "low_confidence_item_count",
    "provenance"
  ],
  "properties": {
    "meeting_extraction_id": { "type": "string", "format": "uuid" },
    "source_artifact_id": { "type": "string", "format": "uuid" },
    "artifact_type": { "const": "meeting_extraction" },
    "schema_version": { "type": "string", "minLength": 1 },
    "prompt_version": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{12}$",
      "description": "Phase P2-B: SHA-256 digest of the extraction prompt template. Changes when the prompt changes. Optional so meeting_extraction artifacts written before Phase P2-B still validate."
    },
    "created_at": { "type": "string" },

    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_text", "decision_type", "stakeholders", "rationale",
          "source_turn_ids", "source_turn_validation", "confidence"
        ],
        "properties": {
          "decision_text": { "type": "string", "minLength": 1 },
          "decision_type": {
            "enum": [
              "approved", "rejected", "deferred", "noted", "considered",
              "action_required", "open_question", "to_be_determined"
            ]
          },
          "stakeholders": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rationale": { "type": ["string", "null"] },
          "source_turn_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "source_turn_validation": {
            "enum": ["verified", "invalid", "missing"]
          },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "items_requiring_review": { "type": "boolean" },
          "review_reason": { "type": "string" },
          "requires_human_dedup": { "type": "boolean" },
          "verification_status": { "type": "string" },
          "verification_id": { "type": ["string", "null"] },
          "decision_outcome": {
            "type": "string",
            "enum": [
              "approval", "rejection", "deferral",
              "action_required", "noted", "question"
            ],
            "description": "Phase T.1: outcome class grounded in regulatory verb from source text."
          },
          "binding_valid": { "type": "boolean" },
          "regulatory_verb_count": { "type": "integer", "minimum": 0 },
          "binding_weak": { "type": "boolean" },
          "binding_ambiguous": { "type": "boolean" },
          "grounded": { "type": "boolean" },
          "grounding_overlap": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "grounding_verified": {
            "type": "boolean",
            "description": "Phase T.2: True when grounding_overlap >= GROUNDING_THRESHOLD."
          },
          "grounding_overlap_score": {
            "type": "number", "minimum": 0.0, "maximum": 1.0,
            "description": "Phase T.2: alias of grounding_overlap surfaced per-item."
          },
          "speaker": { "type": ["string", "null"] },
          "speaker_ambiguous": { "type": "boolean" },
          "atomic_facts": {
            "type": ["array", "null"],
            "items": { "type": "string", "minLength": 1 },
            "description": "Phase T.7: atomic factual decomposition (feature-flagged)."
          },
          "atomic_decomposition_model": { "type": ["string", "null"] },
          "binding_tuple": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "description": "Phase V.5: multi-property binding tuple for decisions. Null when BINDING_TUPLE_ENABLED=false (default) or when the second-pass parse failed.",
            "properties": {
              "actor": { "type": ["string", "null"] },
              "action_verb": { "type": ["string", "null"] },
              "object_description": { "type": ["string", "null"] },
              "band_or_spectrum_ref": { "type": ["string", "null"] },
              "constraint_or_condition": { "type": ["string", "null"] }
            }
          },
          "reason": {
            "type": "string",
            "minLength": 5,
            "maxLength": 500,
            "description": "Phase 3.A (additive, optional). Why the speaker is making this claim/decision/action/etc. Must be derivable from the source span. Required by the meeting_minutes prompt; optional in JSON Schema for backward-compat with pre-3.A artifacts."
          }
        }
      }
    },

    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_text", "claim_type", "speaker",
          "source_turn_ids", "source_turn_validation", "confidence"
        ],
        "properties": {
          "claim_text": { "type": "string", "minLength": 1 },
          "claim_type": {
            "enum": ["technical", "procedural", "regulatory", "opinion"]
          },
          "speaker": { "type": "string" },
          "source_turn_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "source_turn_validation": {
            "enum": ["verified", "invalid", "missing"]
          },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "items_requiring_review": { "type": "boolean" },
          "review_reason": { "type": "string" },
          "requires_human_dedup": { "type": "boolean" },
          "verification_status": { "type": "string" },
          "verification_id": { "type": ["string", "null"] },
          "grounded": { "type": "boolean" },
          "grounding_overlap": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "grounding_verified": { "type": "boolean" },
          "grounding_overlap_score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "speaker_ambiguous": { "type": "boolean" },
          "reason": {
            "type": "string",
            "minLength": 5,
            "maxLength": 500,
            "description": "Phase 3.A (additive, optional). Why the speaker is making this claim/decision/action/etc. Must be derivable from the source span. Required by the meeting_minutes prompt; optional in JSON Schema for backward-compat with pre-3.A artifacts."
          }
        }
      }
    },

    "action_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action", "owner", "due",
          "source_turn_ids", "source_turn_validation", "confidence"
        ],
        "properties": {
          "action": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "due": { "type": ["string", "null"] },
          "source_turn_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "source_turn_validation": {
            "enum": ["verified", "invalid", "missing"]
          },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "items_requiring_review": { "type": "boolean" },
          "review_reason": { "type": "string" },
          "requires_human_dedup": { "type": "boolean" },
          "verification_status": { "type": "string" },
          "verification_id": { "type": ["string", "null"] },
          "grounded": { "type": "boolean" },
          "grounding_overlap": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "grounding_verified": { "type": "boolean" },
          "grounding_overlap_score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "speaker": { "type": ["string", "null"] },
          "speaker_ambiguous": { "type": "boolean" },
          "reason": {
            "type": "string",
            "minLength": 5,
            "maxLength": 500,
            "description": "Phase 3.A (additive, optional). Why the speaker is making this claim/decision/action/etc. Must be derivable from the source span. Required by the meeting_minutes prompt; optional in JSON Schema for backward-compat with pre-3.A artifacts."
          }
        }
      }
    },

    "total_chunks_classified": { "type": "integer", "minimum": 0 },
    "off_topic_count": { "type": "integer", "minimum": 0 },
    "regulatory_verb_fallback_count": { "type": "integer", "minimum": 0 },
    "routing_quality_warning": { "type": "boolean" },
    "requires_human_dedup_count": { "type": "integer", "minimum": 0 },
    "extraction_run_id": { "type": "string", "minLength": 1 },

    "few_shot_injected": { "type": "boolean" },
    "few_shot_version": { "type": ["string", "null"] },
    "few_shot_example_count": { "type": "integer", "minimum": 0 },
    "omit_instruction_present": { "type": "boolean" },
    "confidence_threshold": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "low_confidence_item_count": { "type": "integer", "minimum": 0 },

    "verification_artifact_id": { "type": ["string", "null"] },

    "extraction_mode": {
      "type": "string",
      "enum": ["two_stage", "single_pass"],
      "description": "Phase P3-A T-2: routing mode. ``two_stage`` is the default. ``single_pass`` is the rollback path (env var ``EXTRACTION_MODE=single_pass`` skips chunk classification + per-type extractors and runs a single combined prompt). Optional so artifacts written before Phase P3-A still validate."
    },
    "glossary_version": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Phase P3-A T-3: integer ``glossary_version`` of the versioned glossary artifact injected into prompts during this run. Distinct from ``prompt_version`` so a glossary edit (no prompt template change) is still traceable. Null when no versioned glossary was loaded."
    },
    "off_topic_rate": {
      "type": "number", "minimum": 0.0, "maximum": 1.0,
      "description": "Phase P3-A T-2: fraction of classifier output that came back as ``off_topic``."
    },
    "extraction_path_breakdown": {
      "type": "object",
      "additionalProperties": false,
      "description": "Phase P3-A T-2: map of classification label to count across this run.",
      "required": ["decision", "claim", "action_item", "off_topic"],
      "properties": {
        "decision": { "type": "integer", "minimum": 0 },
        "claim": { "type": "integer", "minimum": 0 },
        "action_item": { "type": "integer", "minimum": 0 },
        "off_topic": { "type": "integer", "minimum": 0 }
      }
    },
    "source_turn_orphan_rate": {
      "type": "number", "minimum": 0.0, "maximum": 1.0,
      "description": "Phase P3-A T-1: fraction of extracted items whose ``source_turn_ids`` cite a chunk_id not present in chunks.jsonl."
    },
    "source_turn_diversity_rate": {
      "type": "number", "minimum": 0.0, "maximum": 1.0,
      "description": "Phase P3-A T-1: distinct cited turns divided by total available turns. Low values mean the model is over-citing a tiny chunk cluster."
    },
    "stakeholders_populated_rate": {
      "type": "number", "minimum": 0.0, "maximum": 1.0,
      "description": "Phase P3-A T-3: fraction of decisions with a non-empty stakeholders list. Rates < 0.8 emit a warn finding ``low_field_population_rate``."
    },
    "rationale_populated_rate": {
      "type": "number", "minimum": 0.0, "maximum": 1.0,
      "description": "Phase P3-A T-3: fraction of decisions with a non-empty rationale string."
    },
    "claim_type_populated_rate": {
      "type": "number", "minimum": 0.0, "maximum": 1.0,
      "description": "Phase P3-A T-3: fraction of claims with a non-empty claim_type."
    },

    "provenance": {
      "type": "object",
      "required": ["produced_by"],
      "properties": {
        "produced_by": { "type": "string", "minLength": 1 },
        "phase": { "type": "string" }
      }
    }
  }
}
