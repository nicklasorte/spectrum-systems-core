{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/src/schemas/calibration_warning.schema.json",
  "title": "calibration_warning",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "run_id",
    "high_confidence_rate",
    "threshold",
    "finding"
  ],
  "properties": {
    "artifact_type": { "const": "calibration_warning" },
    "schema_version": { "const": "1.0.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "high_confidence_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "threshold": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "finding": { "type": "string", "minLength": 1 },
    "items_total": { "type": "integer", "minimum": 0 },
    "items_above_high_confidence": { "type": "integer", "minimum": 0 },
    "high_confidence_cutoff": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "created_at": { "type": "string" }
  }
}
