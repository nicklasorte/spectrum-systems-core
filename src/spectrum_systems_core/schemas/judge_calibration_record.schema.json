{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/src/schemas/judge_calibration_record.schema.json",
  "title": "judge_calibration_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "record_id",
    "judge_score_id",
    "pairs_compared",
    "agreement_rate_overall",
    "agreement_rate_verb_discrimination",
    "verb_discrimination_pairs",
    "calibration_status",
    "provenance"
  ],
  "properties": {
    "artifact_type": { "const": "judge_calibration_record" },
    "schema_version": { "const": "1.0.0" },
    "record_id": { "type": "string", "minLength": 1 },
    "judge_score_id": { "type": "string", "minLength": 1 },
    "pairs_compared": { "type": "integer", "minimum": 0 },
    "agreement_rate_overall": {
      "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0
    },
    "agreement_rate_verb_discrimination": {
      "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0
    },
    "verb_discrimination_pairs": { "type": "integer", "minimum": 0 },
    "calibration_status": {
      "enum": ["unrun", "ok", "warn", "failed"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by"],
      "properties": {
        "produced_by": { "const": "JudgeCalibrationRunner" }
      }
    }
  }
}
