{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/src/schemas/eval_summary.schema.json",
  "title": "eval_summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "run_id",
    "created_at",
    "totals"
  ],
  "properties": {
    "artifact_type": { "const": "eval_summary" },
    "schema_version": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pass", "fail", "warn"],
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "warn": { "type": "integer", "minimum": 0 }
      }
    },
    "chunks_blocked": { "type": "integer", "minimum": 0 },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "eval_results": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
