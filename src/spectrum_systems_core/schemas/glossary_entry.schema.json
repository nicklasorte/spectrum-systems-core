{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems-core/src/schemas/glossary_entry.schema.json",
  "title": "glossary_entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "term",
    "aliases",
    "definition",
    "authoritative_source",
    "category",
    "created_at",
    "is_acronym",
    "disambiguation_required",
    "co_occurring_terms",
    "priority_weight"
  ],
  "properties": {
    "artifact_type": { "const": "glossary_entry" },
    "schema_version": { "const": "1.0.0" },
    "term": { "type": "string", "minLength": 1, "maxLength": 80 },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 80 }
    },
    "definition": { "type": "string", "minLength": 1 },
    "authoritative_source": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "is_acronym": { "type": "boolean" },
    "disambiguation_required": { "type": "boolean" },
    "co_occurring_terms": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "priority_weight": { "type": "number", "minimum": 0.1, "maximum": 10.0 }
  }
}
